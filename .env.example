# Database connection. The app reads DATABASE_URL and runs unchanged on either.

# Default: local SQLite file (zero setup).
# Relative paths resolve under Flask's instance folder -> instance/k2_erp.db
DATABASE_URL=sqlite:///k2_erp.db

# PostgreSQL example (use with: docker compose --profile postgres up)
# DATABASE_URL=postgresql+psycopg://k2:k2@db:5432/k2_erp
